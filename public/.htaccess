# ─────────────────────────────────────────────────────────────────────────────
# .htaccess for React + Vite on cPanel / Apache shared hosting
# Place this file at the root of public_html (alongside index.html)
# ─────────────────────────────────────────────────────────────────────────────

Options -Indexes

# ── MIME types ────────────────────────────────────────────────────────────────
# Ensure JS modules are served with the correct type (critical for ES modules)
AddType application/javascript          .js .mjs
AddType text/css                        .css
AddType image/svg+xml                   .svg
AddType image/png                       .png
AddType image/jpeg                      .jpg .jpeg
AddType image/webp                      .webp
AddType video/mp4                       .mp4
AddType font/woff2                      .woff2
AddType font/woff                       .woff

# ── Enable mod_rewrite ────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback: serve index.html for all other requests (SPA / client-side routing)
  RewriteRule ^ /index.html [L]
</IfModule>

# ── Caching ───────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Vite hashes JS/CSS filenames → safe to cache aggressively
  <FilesMatch "\.(js|css|woff2|woff)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images: moderate caching
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico)$">
    ExpiresDefault "access plus 30 days"
  </FilesMatch>

  # HTML must never be cached — it references the hashed filenames
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
